# Server
PORT=3001
PUBLIC_BASE_URL=https://your-domain.example.com
AUTH_SECRET=change-this-to-a-long-random-string
COMPANY_NAME=Auto Calling CRM
DATABASE_URL=

# Telephony mode:
# simulation = current demo mode
# live = call provider adapter will be used
CALL_MODE=simulation

# Provider choice: twilio, exotel, myoperator, knowlarity, asterisk
TELEPHONY_PROVIDER=twilio

# Company calling number purchased from provider
COMPANY_CALLER_ID=+910000000000

# Twilio example values
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Exotel example values
EXOTEL_ACCOUNT_SID=
EXOTEL_API_KEY=
EXOTEL_API_TOKEN=
EXOTEL_SUBDOMAIN=api.exotel.com
EXOTEL_CALLER_ID=

# MyOperator / Knowlarity placeholders
MYOPERATOR_API_KEY=
KNOWLARITY_API_KEY=
